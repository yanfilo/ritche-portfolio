# Cloudflare Pages/Workers — Response Headers
# Prevents browser "Save As" prompt on images and HTML assets.
# The Portfolio PDF is on Google Drive (external) — no rule needed here.

# Site-wide hardening headers (applies to every route, including "/").
# NOTE: if you add a new external embed/script/font later, update the
# Content-Security-Policy allowlist below or that resource will be blocked.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  # 1-year HSTS, applied to all subdomains. Every subdomain (current and
  # future project subdomains) must serve valid HTTPS. Cloudflare provisions
  # certs automatically for proxied records, so this stays safe as long as new
  # subdomains remain proxied and HTTPS. "preload" is intentionally omitted:
  # it is a stickier, hard-to-reverse commitment. Add it deliberately if ever
  # wanted. If HSTS is also enabled in the Cloudflare dashboard, disable it
  # there so this file is the single source of truth (avoids a duplicate header).
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/images/*
  Content-Disposition: inline
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=3600

/assets/*
  Content-Disposition: inline
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=3600

/docs/*.html
  Content-Disposition: inline
  X-Robots-Tag: noindex, nosnippet
  Cache-Control: no-store

/docs/*.css
  Content-Disposition: inline
  Cache-Control: no-store
